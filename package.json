{
  "name": "mdbasics",
  "version": "0.1.0",
  "description": "A minimal desktop Markdown code editor for native Markdown files.",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron .",
    "verify": "node --check src/main.js && node --check src/preload.js && node --check src/renderer.js && node --check src/modules/diff.js && node --check src/modules/display.js && node --check src/modules/table-editing.js",
    "pack": "electron-builder --dir",
    "dist": "electron-builder --win nsis",
    "release:win": "npm run verify && npm run dist"
  },
  "keywords": [
    "markdown",
    "editor",
    "electron"
  ],
  "author": "Jacques Kruger",
  "license": "MIT",
  "build": {
    "appId": "za.jacqueskruger.mdbasics",
    "productName": "MDBasics",
    "directories": {
      "output": "dist"
    },
    "artifactName": "${productName}-${version}-Setup-${arch}.${ext}",
    "files": [
      "index.html",
      "src/**/*",
      "package.json",
      "node_modules/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "MDBasics"
    }
  },
  "devDependencies": {
    "electron": "^41.4.0",
    "electron-builder": "^26.8.1"
  },
  "dependencies": {
    "marked": "^16.4.1",
    "pandoc-wasm": "^1.0.1",
    "sanitize-html": "^2.17.3",
    "turndown": "^7.2.1"
  }
}
