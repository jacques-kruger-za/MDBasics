{
  "name": "mdbasics",
  "version": "0.1.3",
  "description": "A minimal desktop Markdown code editor for native Markdown files.",
  "main": "src/main.js",
  "scripts": {
    "build:codemirror": "esbuild src/codemirror-entry.js --bundle --format=iife --target=chrome120 --outfile=src/vendor/codemirror.bundle.js",
    "start": "npm run build:codemirror && electron .",
    "dev": "npm run build:codemirror && electron .",
    "verify": "npm run build:codemirror && node --check src/main.js && node --check src/preload.js && node --check src/renderer.js && node --check src/modules/diff.js && node --check src/modules/display.js && node --check src/modules/table-editing.js && node --check src/modules/scroll-sync.js",
    "pack": "electron-builder --dir",
    "dist": "electron-builder --win nsis",
    "release:win": "npm run verify && npm run dist"
  },
  "keywords": [
    "markdown",
    "editor",
    "electron"
  ],
  "author": "Jacques Kruger",
  "license": "MIT",
  "build": {
    "appId": "za.jacqueskruger.mdbasics",
    "productName": "MDBasics",
    "directories": {
      "output": "dist"
    },
    "artifactName": "${productName}-${version}-Setup-${arch}.${ext}",
    "files": [
      "index.html",
      "src/**/*",
      "package.json",
      "node_modules/**/*"
    ],
    "fileAssociations": [
      {
        "ext": [
          "md",
          "markdown",
          "mdown",
          "mkd"
        ],
        "name": "Markdown Document",
        "description": "Markdown document",
        "role": "Editor"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "MDBasics"
    }
  },
  "devDependencies": {
    "electron": "^41.4.0",
    "electron-builder": "^26.8.1",
    "esbuild": "^0.28.0"
  },
  "dependencies": {
    "@codemirror/autocomplete": "^6.20.1",
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/language": "^6.12.3",
    "@codemirror/language-data": "^6.5.2",
    "@codemirror/search": "^6.7.0",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.41.1",
    "marked": "^16.4.1",
    "pandoc-wasm": "^1.0.1",
    "sanitize-html": "^2.17.3",
    "turndown": "^7.2.1"
  }
}
